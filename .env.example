# =============================================================================
# Velox Edge — minimum viable config. Copy to .env and fill in.
# =============================================================================

# === Alpaca (paper account; data + execution) ===
ALPACA_API_KEY=<your-paper-key>
ALPACA_SECRET_KEY=<your-paper-secret>
ALPACA_PAPER=true

# === AI providers ===
# The two voters (Claude + GPT) make the trade decisions.
# Perplexity is the context layer — one call per session, market brief
# injected into both voters' prompts. No Grok in v1.
ANTHROPIC_API_KEY=<your-anthropic-key>
OPENAI_API_KEY=<your-openai-key>
PERPLEXITY_API_KEY=<your-perplexity-key>
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-5.4
PERPLEXITY_MODEL=sonar-pro
MARKET_BRIEF_ENABLED=true

# === Unusual Whales (options flow for contrarian context) ===
UW_API_TOKEN=<your-uw-token>
UW_API_ENABLED=true

# === Trading parameters (CONTRARIAN profile) ===
POSITION_SIZE_PCT=7.0
POSITION_SIZE_MIN_PCT=5.0
POSITION_SIZE_MAX_PCT=10.0
MAX_CONCURRENT_POSITIONS=6
MIN_CONSENSUS_CONFIDENCE=65
MAX_CATEGORY_EXPOSURE_PCT=50
PAPER_STARTING_EQUITY=25000

# === Profit ratchet (WIDER for contrarian fades) ===
RATCHET_HARD_STOP_PCT=-3.00
RATCHET_ACTIVATION_PCT=1.00
RATCHET_TRAIL_PCT=2.00
RATCHET_INITIAL_FLOOR_PCT=0.25
RATCHET_MIN_HOLD_SECONDS=300

# === Hold profile (Edge can carry winners overnight) ===
EDGE_FORCE_FLATTEN_AT_EOD=false
EDGE_MAX_HOLD_DAYS=3

# === Dashboard ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8423
DASHBOARD_TOKEN=<set-a-token>

# === Kill switch (set to true to halt all new entries; existing positions still managed) ===
TRADING_HALTED=false

# === Logging ===
LOG_LEVEL=INFO
